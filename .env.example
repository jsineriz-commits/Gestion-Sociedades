# .env.example
# Copiar como .env.local para desarrollo local
# En Vercel: Settings → Environment Variables

# JSON completo de la Service Account de Google
# Obtenerlo en: Google Cloud Console → IAM → Service Accounts → Crear clave JSON
# La service account necesita acceso de LECTURA a la Google Sheet (compartir la hoja con el email de la SA)
GOOGLE_SERVICE_ACCOUNT_KEY={"type":"service_account","project_id":"...","private_key_id":"...","private_key":"-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----\n","client_email":"tu-sa@tu-proyecto.iam.gserviceaccount.com","client_id":"...","auth_uri":"https://accounts.google.com/o/oauth2/auth","token_uri":"https://oauth2.googleapis.com/token"}
